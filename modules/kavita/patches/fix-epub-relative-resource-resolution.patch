+    private static string NormalizeContentKey(string key)
+    {
+        return key.Replace('\\', '/');
+    }
+
+    private static string? ResolveRelativeContentKey(string? contentFilePath, string key)
+    {
+        if (string.IsNullOrEmpty(contentFilePath) || string.IsNullOrEmpty(key) || Uri.TryCreate(key, UriKind.Absolute, out _))
+        {
+            return null;
+        }
+
+        var contentDirectory = Path.GetDirectoryName(contentFilePath)?.Replace('\\', '/');
+        if (string.IsNullOrEmpty(contentDirectory))
+        {
+            return null;
+        }
+
+        var contentUri = new Uri("https://kavita.invalid/" + contentDirectory.Trim('/') + "/");
+        return NormalizeContentKey(new Uri(contentUri, key).AbsolutePath.TrimStart('/'));
+    }
+
+    private static string? FindUniqueSuffixMatch(IEnumerable<string> keys, string suffix)
+    {
+        var normalizedSuffix = NormalizeContentKey(suffix);
+        var matches = keys
+            .Where(k => NormalizeContentKey(k).EndsWith(normalizedSuffix, StringComparison.Ordinal))
+            .Take(2)
+            .ToList();
+
+        return matches.Count == 1 ? matches[0] : null;
+    }
+
+    private static string? ResolveLocalContentKey(IEnumerable<string> keys, string? contentFilePath, string key)
+    {
+        var availableKeys = keys.ToList();
+        var normalizedKey = NormalizeContentKey(key);
+        var cleanedKey = NormalizeContentKey(CleanContentKeys(key));
+
+        var exactMatch = availableKeys.FirstOrDefault(k => NormalizeContentKey(k) == normalizedKey);
+        if (exactMatch != null) return exactMatch;
+
+        exactMatch = availableKeys.FirstOrDefault(k => NormalizeContentKey(k) == cleanedKey);
+        if (exactMatch != null) return exactMatch;
+
+        var relativeKey = ResolveRelativeContentKey(contentFilePath, key);
+        if (!string.IsNullOrEmpty(relativeKey))
+        {
+            exactMatch = availableKeys.FirstOrDefault(k => NormalizeContentKey(k) == relativeKey);
+            if (exactMatch != null) return exactMatch;
+
+            exactMatch = FindUniqueSuffixMatch(availableKeys, relativeKey);
+            if (exactMatch != null) return exactMatch;
+        }
+
+        exactMatch = FindUniqueSuffixMatch(availableKeys, normalizedKey);
+        if (exactMatch != null) return exactMatch;
+
+        return FindUniqueSuffixMatch(availableKeys, cleanedKey);
+    }
