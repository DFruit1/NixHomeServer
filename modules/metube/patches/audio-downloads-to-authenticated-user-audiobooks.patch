+def _normalise_authenticated_username(value):
+    if not value:
+        return None
+
+    candidate = str(value).split(',', 1)[0].strip()
+    if not candidate:
+        return None
+
+    local_part = candidate.split('@', 1)[0]
+    if not re.fullmatch(r'[A-Za-z0-9._-]{1,64}', local_part):
+        return None
+    return local_part
+
+
+def _authenticated_audio_download_dir(request):
+    for header_name in (
+        'X-Forwarded-User',
+        'X-Auth-Request-User',
+        'X-Forwarded-Email',
+        'X-Auth-Request-Email',
+    ):
+        username = _normalise_authenticated_username(request.headers.get(header_name))
+        if username:
+            break
+    else:
+        raise web.HTTPUnauthorized(reason='missing authenticated user header for audio download')
+
+    audio_root = os.path.realpath(config.AUDIO_DOWNLOAD_DIR)
+    target_dir = os.path.realpath(os.path.join(audio_root, username, 'audiobooks'))
+    audio_root_with_sep = audio_root if audio_root.endswith(os.sep) else audio_root + os.sep
+    if target_dir != audio_root and not target_dir.startswith(audio_root_with_sep):
+        raise web.HTTPBadRequest(reason='authenticated audio download directory resolved outside the audio root')
+    if not os.path.isdir(target_dir):
+        raise web.HTTPBadRequest(
+            reason=f'audiobooks directory for authenticated user "{username}" does not exist',
+        )
+    return target_dir
+
+
+def _apply_authenticated_audio_target(request, download_options):
+    if download_options['download_type'] == 'audio':
+        download_options['download_dir_override'] = _authenticated_audio_download_dir(request)
+    else:
+        download_options['download_dir_override'] = None
+
+
